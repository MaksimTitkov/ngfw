# ── NGFW Manager v2.0 — Пример конфигурации ─────────────────────────────────
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env

# Заголовок приложения (отображается в интерфейсе)
APP_TITLE="NGFW Manager"

# Секретный ключ сессий — сгенерируйте случайную строку:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-min-32-chars

# Пароль базы данных PostgreSQL (должен совпадать с docker-compose.yml)
DB_PASSWORD=change_me_strong_password

# Локальный read-only аккаунт (оставьте RO_PASSWORD пустым для отключения)
RO_USERNAME=readonly
RO_PASSWORD=
